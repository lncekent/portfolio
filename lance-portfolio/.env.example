# ============================================================
# ENVIRONMENT VARIABLES — LANCE PORTFOLIO
# ============================================================
# Copy this file and rename it to .env
# NEVER commit your real .env file to Git!
# ============================================================

# EmailJS (if you add a contact form in the future)
# Get your keys at: https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Cloudinary (if you move from hardcoded URLs to dynamic uploads)
# Get your keys at: https://cloudinary.com/
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# Supabase (if you add a backend/database in the future)
# Get your keys at: https://supabase.com/
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
